cff-version: 1.2.0
title: "High-Frequency Identification of Equity-Bond Comovement: Companion Code"
message: "If you use this code, please cite as below."
type: software
authors:
  - given-names: Francesco
    family-names: De Marte
    affiliation: "Bocconi University"
